{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Switchyard Asset Bundle",
  "type": "object",
  "required": [
    "version",
    "catalog",
    "snapshots"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "catalog": {
      "type": "string",
      "minLength": 1
    },
    "snapshots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "path"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
